{
  "entryFile": "src/app.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/**/*.controller.ts"],
  "spec": {
    "outputDirectory": "public",
    "specVersion": 3
  },
    "routes": {
    "routesDir": "src"
  },
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@database/*": ["./database/*"],
      "@test/*": ["./test/*"],
      "@config/*": ["./config/*"],
      "@controllers/*": ["./controllers/*"],
      "@services/*": ["./services/*"],
      "@models/*": ["./models/*"],
      "@errors/*": ["./errors/*"],
      "@type/*": ["./type/*"],
      "@constants/*": ["./constants/*"]
    }
  }
}
